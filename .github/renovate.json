{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>SonarSource/renovate-config:quality-corelang-squad"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "org.eclipse.jdt:org.eclipse.jdt.core"
      ],
      "enabled": false
    },
    {
      "matchFileNames": [
        "build-eclipse-jdt-core-branch/**"
      ],
      "extends": [
        "schedule:quarterly"
      ]
    }
  ]
}
